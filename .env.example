# ─── EDGX News Broadcast — required for the hourly broadcast feature ───
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_JANE=female_voice_id_here
ELEVENLABS_VOICE_BRANDON=male_voice_id_here

# Optional
# BROADCAST_DIR=/data    # Railway Volume mount path — REQUIRED for durable storage across redeploys
# BROADCAST_AUTORUN=off  # disable the hourly cron scheduler
# PORT=3000
